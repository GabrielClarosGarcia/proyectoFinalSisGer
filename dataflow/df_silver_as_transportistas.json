{
	"name": "df_silver_as_transportistas",
	"properties": {
		"folder": {
			"name": "silver/AS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronce_as_transportistas",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          transportista_id as string,",
				"          razon_social as string,",
				"          nit as string,",
				"          municipio as string,",
				"          contacto as string,",
				"          telefono as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    TRIM(transportista_id) AS transportista_id,\\n    TRIM(razon_social) AS razon_social,\\n    TRIM(nit) AS nit,\\n    TRIM(municipio) AS municipio,\\n    TRIM(contacto) AS contacto,\\n    TRIM(telefono) AS telefono,\\n    TRIM(estado) AS estado\\nFROM bronze.as_transportistas\\nWHERE transportista_id IS NOT NULL \\n  AND TRIM(transportista_id) <> \\'\\'',",
				"     format: 'query') ~> source1",
				"source1 derive(transportista_id = toInteger(transportista_id),",
				"          razon_social = upper(regexReplace(trim(razon_social), '\\\\s+', ' ')),",
				"          nit = regexReplace(trim(nit), '\\\\s+', ''),",
				"          municipio = initCap(regexReplace(trim(municipio), '\\\\s+', ' ')),",
				"          contacto = initCap(regexReplace(trim(contacto), '\\\\s+', ' ')),",
				"          telefono = regexReplace(trim(telefono), '[^0-9]', ''),",
				"          estado = case(     in(['activo','ACTIVO','Activo'], estado), 'ACTIVO',     in(['inactivo','INACTIVO','Inactivo'], estado), 'INACTIVO',     isNull(estado), 'SIN_ESTADO',     upper(trim(estado)) ),",
				"          registro_valido = iif(isNull(transportista_id), false(), true()),",
				"          observacion_calidad = iif(isNull(transportista_id), 'transportista_id inválido', 'OK')) ~> derivedColumn1"
			]
		}
	}
}