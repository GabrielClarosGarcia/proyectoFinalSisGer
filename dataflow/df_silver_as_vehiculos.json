{
	"name": "df_silver_as_vehiculos",
	"properties": {
		"folder": {
			"name": "silver/AS"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronce_as_vehiculos",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_as_vehiculos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          vehiculo_id as string,",
				"          transportista_id as string,",
				"          descripcion as string,",
				"          placa as string,",
				"          tipo as string,",
				"          capacidad_kg as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    TRIM(vehiculo_id) AS vehiculo_id,\\n    TRIM(transportista_id) AS transportista_id,\\n    TRIM(descripcion) AS descripcion,\\n    TRIM(placa) AS placa,\\n    TRIM(tipo) AS tipo,\\n    TRIM(capacidad_kg) AS capacidad_kg,\\n    TRIM(estado) AS estado\\nFROM bronze.as_vehiculos\\nWHERE vehiculo_id IS NOT NULL \\n  AND TRIM(vehiculo_id) <> \\'\\'',",
				"     format: 'query') ~> source1",
				"source1 derive(vehiculo_id = toInteger(vehiculo_id),",
				"          transportista_id = toInteger(transportista_id),",
				"          descripcion = initCap(regexReplace(trim(descripcion), '\\\\s+', ' ')),",
				"          placa = upper(regexReplace(trim(placa), '\\\\s+', '')),",
				"          tipo = initCap(regexReplace(trim(tipo), '\\\\s+', ' ')),",
				"          capacidad_kg = toDecimal(regexReplace(toString(capacidad_kg), '[^0-9.]', '')),",
				"          estado = case(     in(['activo','ACTIVO','Activo'], estado), 'ACTIVO',     in(['inactivo','INACTIVO','Inactivo'], estado), 'INACTIVO',     isNull(estado), 'SIN_ESTADO',     upper(trim(estado)) ),",
				"          registro_valido = iif(isNull(vehiculo_id) || isNull(transportista_id), false(), true()),",
				"          observacion_calidad = case(     isNull(vehiculo_id), 'vehiculo_id inválido',     isNull(transportista_id), 'transportista_id inválido',     'OK' )) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          vehiculo_id as integer,",
				"          transportista_id as integer,",
				"          descripcion as string,",
				"          placa as string,",
				"          tipo as string,",
				"          capacidad_kg as decimal(18,2),",
				"          estado as string,",
				"          registro_valido as boolean,",
				"          observacion_calidad as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          vehiculo_id,",
				"          transportista_id,",
				"          descripcion,",
				"          placa,",
				"          tipo,",
				"          capacidad_kg,",
				"          estado,",
				"          registro_valido,",
				"          observacion_calidad",
				"     )) ~> sink1"
			]
		}
	}
}