{
	"name": "df_bja_partos",
	"properties": {
		"folder": {
			"name": "silver/BJA"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronce_bja_partos",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_bja_partos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          parto_id as string,",
				"          ci_madre_original as string,",
				"          ci_madre_normalizado as string,",
				"          ci_recien_nacido_original as string,",
				"          ci_recien_nacido_normalizado as string,",
				"          establecimiento_id as string,",
				"          fecha_parto as string,",
				"          tipo_parto as string,",
				"          peso_nacimiento_kg as string,",
				"          talla_nacimiento_cm as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    TRIM(parto_id) AS parto_id,\\n    TRIM(ci_madre) AS ci_madre_original,\\n    TRIM(ci_madre) AS ci_madre_normalizado,\\n    TRIM(ci_recien_nacido) AS ci_recien_nacido_original,\\n    TRIM(ci_recien_nacido) AS ci_recien_nacido_normalizado,\\n    TRIM(establecimiento_id) AS establecimiento_id,\\n    TRIM(fecha_parto) AS fecha_parto,\\n    TRIM(tipo_parto) AS tipo_parto,\\n    TRIM(peso_nacimiento_kg) AS peso_nacimiento_kg,\\n    TRIM(talla_nacimiento_cm) AS talla_nacimiento_cm\\nFROM bronze.bja_partos\\nWHERE parto_id IS NOT NULL\\n  AND TRIM(parto_id) <> \\'\\'',",
				"     format: 'query') ~> source1",
				"source1 derive(parto_id = toInteger(parto_id),",
				"          ci_madre_normalizado = upper(regexReplace(regexReplace(regexReplace(trim(ci_madre_normalizado), '-', ''), '\\\\s+', ''), '\\\\.', '')),",
				"          ci_recien_nacido_normalizado = upper(regexReplace(regexReplace(regexReplace(trim(ci_recien_nacido_normalizado), '-', ''), '\\\\s+', ''), '\\\\.', '')),",
				"          establecimiento_id = toInteger(establecimiento_id),",
				"          fecha_parto = coalesce(     toDate(fecha_parto, 'yyyy-MM-dd'),     toDate(fecha_parto, 'dd/MM/yyyy'),     toDate(fecha_parto, 'MM/dd/yyyy'),     toDate(fecha_parto, 'dd-MM-yyyy') ),",
				"          tipo_parto = case(     in(['Natural','NATURAL','natural','Nautral'], tipo_parto), 'NATURAL',     in(['Cesárea','CESÁREA','cesárea','Cesarea','CESAREA','Cesárae'], tipo_parto), 'CESAREA',     isNull(tipo_parto), 'SIN_DATO',     upper(trim(tipo_parto)) ),",
				"          peso_nacimiento_kg = toDecimal(regexReplace(toString(peso_nacimiento_kg), '[^0-9.]', '')),",
				"          talla_nacimiento_cm = toDecimal(regexReplace(toString(talla_nacimiento_cm), '[^0-9.]', '')),",
				"          registro_valido = iif(     isNull(parto_id) ||     isNull(ci_madre_normalizado) ||     isNull(fecha_parto),     false(),     true() ),",
				"          observacion_calidad = case(     isNull(parto_id), 'parto_id inválido',     isNull(ci_madre_normalizado), 'CI madre inválido',     isNull(fecha_parto), 'fecha_parto inválida',     'OK' )) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          parto_id as integer,",
				"          ci_madre_original as string,",
				"          ci_madre_normalizado as string,",
				"          ci_recien_nacido_original as string,",
				"          ci_recien_nacido_normalizado as string,",
				"          establecimiento_id as integer,",
				"          fecha_parto as date,",
				"          tipo_parto as string,",
				"          peso_nacimiento_kg as decimal(10,2),",
				"          talla_nacimiento_cm as decimal(10,2),",
				"          registro_valido as boolean,",
				"          observacion_calidad as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          parto_id,",
				"          ci_madre_original,",
				"          ci_madre_normalizado,",
				"          ci_recien_nacido_original,",
				"          ci_recien_nacido_normalizado,",
				"          establecimiento_id,",
				"          fecha_parto,",
				"          tipo_parto,",
				"          peso_nacimiento_kg,",
				"          talla_nacimiento_cm,",
				"          registro_valido,",
				"          observacion_calidad",
				"     )) ~> sink1"
			]
		}
	}
}