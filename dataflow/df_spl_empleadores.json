{
	"name": "df_spl_empleadores",
	"properties": {
		"folder": {
			"name": "silver/SPL"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronce_spl_empleadores",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          empleador_id as string,",
				"          nit as string,",
				"          razon_social as string,",
				"          tipo as string,",
				"          nro_patronal as string,",
				"          municipio as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    TRIM(empleador_id) AS empleador_id,\\n    TRIM(nit) AS nit,\\n    TRIM(razon_social) AS razon_social,\\n    TRIM(tipo) AS tipo,\\n    TRIM(nro_patronal) AS nro_patronal,\\n    TRIM(municipio) AS municipio\\nFROM bronze.spl_empleadores\\nWHERE empleador_id IS NOT NULL\\n  AND TRIM(empleador_id) <> \\'\\'',",
				"     format: 'query') ~> source1",
				"source1 derive(empleador_id = toInteger(empleador_id),",
				"          nit = regexReplace(trim(nit), '\\\\s+', ''),",
				"          razon_social = upper(regexReplace(trim(razon_social), '\\\\s+', ' ')),",
				"          tipo = initCap(regexReplace(trim(tipo), '\\\\s+', ' ')),",
				"          nro_patronal = upper(regexReplace(trim(nro_patronal), '\\\\s+', '')),",
				"          municipio = initCap(regexReplace(trim(municipio), '\\\\s+', ' ')),",
				"          registro_valido = iif(isNull(empleador_id), false(), true()),",
				"          observacion_calidad = iif(isNull(empleador_id), 'empleador_id inválido', 'OK')) ~> derivedColumn1"
			]
		}
	}
}