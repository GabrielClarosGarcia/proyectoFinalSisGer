{
	"name": "df_gold_dim_beneficiaria",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "gold_dim_beneficiaria",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_beneficiaria",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          beneficiaria_key as integer,",
				"          ci_normalizado as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          fecha_nacimiento as date,",
				"          genero as string,",
				"          estado_civil as string,",
				"          municipio_residencia as string,",
				"          numero_hijos as integer,",
				"          profesion as string,",
				"          nivel_estudios as string,",
				"          fuente_identidad as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT DISTINCT\\n    ci_normalizado,\\n    nombres,\\n    apellido_paterno,\\n    apellido_materno,\\n    fecha_nacimiento,\\n    genero,\\n    estado_civil,\\n    municipio_residencia,\\n    numero_hijos,\\n    profesion,\\n    nivel_estudios,\\n    \\'SEGIP\\' AS fuente_identidad\\nFROM silver.segip_personas\\nWHERE ci_normalizado IS NOT NULL\\n  AND registro_valido = 1',",
				"     format: 'query') ~> source1",
				"source1 derive(ci_normalizado = upper(regexReplace(regexReplace(regexReplace(trim(ci_normalizado), '-', ''), '\\\\s+', ''), '\\\\.', '')),",
				"          nombres = initCap(regexReplace(trim(nombres), '\\\\s+', ' ')),",
				"          apellido_paterno = initCap(regexReplace(trim(apellido_paterno), '\\\\s+', ' ')),",
				"          apellido_materno = initCap(regexReplace(trim(apellido_materno), '\\\\s+', ' ')),",
				"          genero = upper(trim(genero)),",
				"          estado_civil = upper(trim(estado_civil)),",
				"          municipio_residencia = initCap(regexReplace(trim(municipio_residencia), '\\\\s+', ' ')),",
				"          numero_hijos = iifNull(toInteger(numero_hijos), 0)) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          beneficiaria_key as integer,",
				"          ci_normalizado as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          fecha_nacimiento as date,",
				"          genero as string,",
				"          estado_civil as string,",
				"          municipio_residencia as string,",
				"          numero_hijos as integer,",
				"          profesion as string,",
				"          nivel_estudios as string,",
				"          fuente_identidad as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          ci_normalizado,",
				"          nombres,",
				"          apellido_paterno,",
				"          apellido_materno,",
				"          fecha_nacimiento,",
				"          genero,",
				"          estado_civil,",
				"          municipio_residencia,",
				"          numero_hijos,",
				"          profesion,",
				"          nivel_estudios,",
				"          fuente_identidad",
				"     )) ~> sink1"
			]
		}
	}
}