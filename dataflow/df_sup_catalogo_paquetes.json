{
	"name": "df_sup_catalogo_paquetes",
	"properties": {
		"folder": {
			"name": "silver/SUP"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronce_sup_catalogo_paquetes",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          paquete_id as string,",
				"          nombre as string,",
				"          contenido as string,",
				"          peso_estandar_kg as string,",
				"          costo_estimado_bs as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    TRIM(paquete_id) AS paquete_id,\\n    TRIM(nombre) AS nombre,\\n    TRIM(contenido) AS contenido,\\n    TRIM(peso_estandar_kg) AS peso_estandar_kg,\\n    TRIM(costo_estimado_bs) AS costo_estimado_bs\\nFROM bronze.sup_catalogo_paquetes\\nWHERE paquete_id IS NOT NULL\\n  AND TRIM(paquete_id) <> \\'\\'',",
				"     format: 'query') ~> source1",
				"source1 derive(paquete_id = toInteger(paquete_id),",
				"          nombre = initCap(regexReplace(trim(nombre), '\\\\s+', ' ')),",
				"          contenido = initCap(regexReplace(trim(contenido), '\\\\s+', ' ')),",
				"          peso_estandar_kg = toDecimal(regexReplace(toString(peso_estandar_kg), '[^0-9.]', '')),",
				"          costo_estimado_bs = toDecimal(regexReplace(toString(costo_estimado_bs), '[^0-9.]', '')),",
				"          registro_valido = iif(isNull(paquete_id), false(), true()),",
				"          observacion_calidad = iif(isNull(paquete_id), 'paquete_id inválido', 'OK')) ~> derivedColumn1"
			]
		}
	}
}