{
	"name": "df_spl_cajas",
	"properties": {
		"folder": {
			"name": "silver/SPL"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronce_spl_cajas",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_spl_cajas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          caja_id as string,",
				"          nombre as string,",
				"          sigla as string,",
				"          tipo as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    TRIM(ID) AS caja_id,\\n    TRIM(Nombre) AS nombre,\\n    TRIM(Sigla) AS sigla,\\n    TRIM(Tipo) AS tipo,\\n    TRIM(Estado) AS estado\\nFROM bronze.spl_cajas\\nWHERE ID IS NOT NULL\\n  AND TRIM(ID) <> \\'\\'',",
				"     format: 'query') ~> source1",
				"source1 derive(caja_id = toInteger(caja_id),",
				"          nombre = initCap(regexReplace(trim(nombre), '\\\\s+', ' ')),",
				"          sigla = upper(regexReplace(trim(sigla), '\\\\s+', '')),",
				"          tipo = initCap(regexReplace(trim(tipo), '\\\\s+', ' ')),",
				"          estado = case(     in(['Activo','ACTIVO','activo'], estado), 'ACTIVO',     in(['Inactivo','INACTIVO','inactivo'], estado), 'INACTIVO',     isNull(estado), 'SIN_ESTADO',     upper(trim(estado)) ),",
				"          registro_valido = iif(isNull(caja_id), false(), true()),",
				"          observacion_calidad = iif(isNull(caja_id), 'caja_id inválido', 'OK')) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          caja_id as integer,",
				"          nombre as string,",
				"          sigla as string,",
				"          tipo as string,",
				"          estado as string,",
				"          registro_valido as boolean,",
				"          observacion_calidad as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          caja_id,",
				"          nombre,",
				"          sigla,",
				"          tipo,",
				"          estado,",
				"          registro_valido,",
				"          observacion_calidad",
				"     )) ~> sink1"
			]
		}
	}
}